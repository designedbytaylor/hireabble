# ========================
# Hireabble Backend - Environment Variables
# Copy this file to .env and fill in your values
# ========================

# --- Required ---
MONGO_URL=mongodb+srv://user:pass@cluster.mongodb.net/
DB_NAME=hireabble
JWT_SECRET=your-jwt-secret-here
FRONTEND_URL=https://hireabble.com

# --- Email (Resend) ---
RESEND_API_KEY=re_xxxxxxxxxxxx
SENDER_EMAIL=noreply@hireabble.com

# --- File Storage (Supabase) ---
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=your-supabase-service-role-key

# --- OAuth Providers ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# --- Payments ---
STRIPE_SECRET_KEY=sk_test_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx
APPLE_SHARED_SECRET=
APPLE_BUNDLE_ID=com.hireabble.app
APPLE_ENVIRONMENT=sandbox
GOOGLE_PLAY_PACKAGE_NAME=com.hireabble.app
GOOGLE_PLAY_SERVICE_ACCOUNT_KEY=

# --- Push Notifications ---
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@hireabble.com

# --- AI ---
ANTHROPIC_API_KEY=

# --- Caching (optional) ---
REDIS_URL=

# --- Error Tracking (optional) ---
SENTRY_DSN=
ENVIRONMENT=production
